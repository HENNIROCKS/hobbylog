__*

# Content
# ----------------------------------
/content/*

# Editors
# (sensitive workspace files)
# ----------------------------------
*.sublime-workspace
/.idea
/.vscode
.vscode/sftp.json

# Kirby
# (except my own plugins)
# ----------------------------------
/kirby/*
/site/plugins/*
!/site/plugins/hb-commons/
!/site/plugins/hb-theme-hobbylog/
/vendor/*
kirby


# Kirby config(s)
# ----------------------------------
/site/config/*
!/site/config/config.php
!/site/config/config.localhost.php

# Lock files
# ----------------------------------
.lock

# Logs and databases
# ----------------------------------
/.sqlite
/site/db/*
/site/logs/*

# Libraries
# ----------------------------------
node_modules

# SvelteKit
# ----------------------------------
frontend/.svelte-kit/
frontend/build/

# System files
# ----------------------------------
.DS_Store
Icon

# Claude Code
# ----------------------------------
.claude/

# Temporary files
# ----------------------------------
/media/*
!/media/index.html

# ############ SECURITY ############
# Never publish these files via Git!
# ############ SECURITY ############

# Accounts
# ----------------------------------
/site/accounts/*
!/site/accounts/index.html

# Cache files
# ----------------------------------
/site/cache/*
!/site/cache/index.html

# Environment variable
# ----------------------------------
**/.env

# License
# ----------------------------------
/site/config/.license

# Sessions
# ----------------------------------
/site/sessions/*
!/site/sessions/index.html